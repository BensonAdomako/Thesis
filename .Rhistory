# 1. Load packages
# -----------------------------
library(rgee)
library(sf)
library(dplyr)
library(readr)
library(slider)
library(lubridate)
library(janitor)
# --- Aggregate ---
arson_nbhd <- arson %>%
group_by(nhood) %>%
summarise(
arson_count = n(),
crime_density = mean(crime_density, na.rm = TRUE),
.groups = "drop"
)
names(arson)
library(tidyverse)   # dplyr, stringr, readr, etc.
library(janitor)     # clean_names()
library(lmtest)      # coeftest()
library(sandwich)    # vcovHC()
# Clean column names
arson <- arson %>% clean_names()
ndvi  <- ndvi  %>% clean_names()
elev  <- elev  %>% clean_names()
# Standardize neighborhood name
fix_key <- function(x) str_to_lower(str_squish(x))
arson <- arson %>% mutate(nhood = fix_key(name))
ndvi  <- ndvi  %>% mutate(nhood = fix_key(name))
elev  <- elev  %>% mutate(nhood = fix_key(name))
# --- Aggregate ---
arson_nbhd <- arson %>%
group_by(nhood) %>%
summarise(
arson_count = n(),
crime_density = mean(crime_density, na.rm = TRUE),
.groups = "drop"
)
ndvi_nbhd <- ndvi %>%
group_by(nhood) %>%
summarise(mean_ndvi = mean(mean, na.rm = TRUE), .groups = "drop")
elev_nbhd <- elev %>%
group_by(nhood) %>%
summarise(sd_elev = mean(std_dev, na.rm = TRUE), .groups = "drop")
# Merge everything
df <- arson_nbhd %>%
left_join(ndvi_nbhd, by = "nhood") %>%
left_join(elev_nbhd, by = "nhood")
View(df)
# Check missing matches (if any)
df %>%
filter(is.na(mean_ndvi) | is.na(sd_elev)) %>%
select(nhood) %>%
distinct() %>%
print(n = Inf)
# Keep complete cases for regressions
df_reg <- df %>% filter(!is.na(mean_ndvi) & !is.na(sd_elev))
m1 <- lm(arson_count ~ mean_ndvi + sd_elev, data = df_reg)
coeftest(m1, vcov = vcovHC(m1, type = "HC1"))
m2 <- lm(log1p(arson_count) ~ mean_ndvi + sd_elev, data = df_reg)
coeftest(m2, vcov = vcovHC(m2, type = "HC1"))
m3 <- glm(arson_count ~ mean_ndvi + sd_elev, data = df_reg, family = poisson())
coeftest(m3, vcov = vcovHC(m3, type = "HC1"))
df_reg <- df_reg %>%
mutate(mean_ndvi_10 = mean_ndvi * 10)
lm(log1p(arson_count) ~ mean_ndvi_10 + sd_elev, data = df_reg) |>
coeftest(vcov = vcovHC(_, type = "HC1"))
m2_scaled <- lm(
log1p(arson_count) ~ mean_ndvi_10 + sd_elev,
data = df_reg
)
coeftest(m2_scaled, vcov = vcovHC(m2_scaled, type = "HC1"))
library(modelsummary)
modelsummary(
list("OLS: log(1 + Arson Incidents)" = m2_scaled),
statistic = "({std.error})",
stars = TRUE,
coef_map = c(
"mean_ndvi_10" = "Mean NDVI (×10)",
"sd_elev"      = "Elevation SD"
),
gof_map = c("nobs", "r.squared"),
output = "markdown"
)
# Clean column names
arson <- arson %>% clean_names()
ndvi  <- ndvi  %>% clean_names()
elev  <- elev  %>% clean_names()
# Standardize neighborhood name
fix_key <- function(x) str_to_lower(str_squish(x))
arson <- arson %>% mutate(nhood = fix_key(name))
ndvi  <- ndvi  %>% mutate(nhood = fix_key(name))
elev  <- elev  %>% mutate(nhood = fix_key(name))
ndvi_nbhd <- ndvi %>%
group_by(nhood) %>%
summarise(mean_ndvi = mean(mean, na.rm = TRUE), .groups = "drop")
elev_nbhd <- elev %>%
group_by(nhood) %>%
summarise(sd_elev = mean(std_dev, na.rm = TRUE), .groups = "drop")
# Merge everything
df <- arson_nbhd %>%
left_join(ndvi_nbhd, by = "nhood") %>%
left_join(elev_nbhd, by = "nhood")
View(df)
# ---- 4) Standardize neighborhood name ----
fix_key <- function(x) stringr::str_to_lower(stringr::str_squish(as.character(x)))
arson <- arson %>% mutate(nhood = fix_key(name))
ndvi  <- ndvi  %>% mutate(nhood = fix_key(name))
elev  <- elev  %>% mutate(nhood = fix_key(name))
# ---- 5) Aggregate NDVI + Elevation by neighborhood (safe) ----
ndvi_nbhd <- ndvi %>%
group_by(nhood) %>%
summarise(mean_ndvi = mean(mean, na.rm = TRUE), .groups = "drop")
# After clean_names(): stdDev -> stddev
elev_nbhd <- elev %>%
group_by(nhood) %>%
summarise(sd_elev = mean(stddev, na.rm = TRUE), .groups = "drop")
View(elev)
# After clean_names(): stdDev -> stddev
elev_nbhd <- elev %>%
group_by(nhood) %>%
summarise(sd_elev = mean(std_dev, na.rm = TRUE), .groups = "drop")
# ---- 6) Merge everything (use arson, not arson_nbhd) ----
df <- arson %>%
select(nhood, name, join_count, crime_density, morecrime_density) %>%  # keep what you need
left_join(ndvi_nbhd, by = "nhood") %>%
left_join(elev_nbhd, by = "nhood")
View(df_reg)
# Keep complete cases for regressions
df_reg <- df %>% filter(!is.na(mean_ndvi) & !is.na(sd_elev))
m2_scaled <- lm(
log1p(join_count) ~ mean_ndvi_10 + sd_elev,
data = df_reg
)
df_reg <- df_reg %>%
mutate(mean_ndvi_10 = mean_ndvi * 10)
m2_scaled <- lm(
log1p(join_count) ~ mean_ndvi_10 + sd_elev,
data = df_reg
)
coeftest(m2_scaled, vcov = vcovHC(m2_scaled, type = "HC1"))
modelsummary(
list("OLS: log(1 + Arson Incidents)" = m2_scaled),
statistic = "({std.error})",
stars = TRUE,
coef_map = c(
"mean_ndvi_10" = "Mean NDVI (×10)",
"sd_elev"      = "Elevation SD"
),
gof_map = c("nobs", "r.squared"),
output = "markdown"
)
modelsummary(
list("OLS: log(1 + Arson Incidents)" = m2_scaled),
statistic = "({std.error})",
stars = TRUE,
coef_map = c(
"mean_ndvi_10" = "Mean NDVI (×10)",
"sd_elev"      = "Elevation SD"
),
gof_map = c("nobs", "r.squared"),
output = "html"
)
